{
  "name": "lexical-rich-editor",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "A rich-text editor built on Lexical, grown one feature at a time.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:embed": "tsc -b && VITE_BASE=/lexical/ vite build",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@lexical/code": "^0.44.0",
    "@lexical/code-prism": "^0.44.0",
    "@lexical/link": "0.44.0",
    "@lexical/list": "0.44.0",
    "@lexical/markdown": "^0.44.0",
    "@lexical/react": "0.44.0",
    "@lexical/rich-text": "0.44.0",
    "@lexical/selection": "0.44.0",
    "@lexical/table": "^0.44.0",
    "@lexical/utils": "0.44.0",
    "clsx": "^2.1.1",
    "katex": "^0.16.47",
    "lexical": "0.44.0",
    "lucide-react": "^0.475.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwind-merge": "^3.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.0.0",
    "@types/katex": "^0.16.8",
